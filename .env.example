# GCP Configuration
# Copy this file and remove the .example extension: cp .env.example .env
# Then fill in your actual values

# Path to your GCP service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcp-service-account.json

# Your GCP Project ID
GCP_PROJECT_ID=your-project-id-here

# BigQuery Dataset (if applicable)
BQ_DATASET=zoomcamp_dataset
BQ_LOCATION=us-central1

# GCS Bucket (if applicable)
GCS_BUCKET=your-bucket-name-here

# Region
GCP_REGION=us-central1

LTA_ACCOUNT_KEY=request-from-LTA-datamall