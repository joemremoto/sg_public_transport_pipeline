# Singapore Public Transport Pipeline - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ==========================================
# GCP Configuration
# ==========================================

# Path to your GCP service account JSON key file
# Use relative path from project root (./credentials/...) or absolute path
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcp-service-account.json

# Your GCP project ID (must match the project created in GCP Console)
GCP_PROJECT_ID=sg-public-transport-pipeline

# GCP region for resources (recommended: asia-east1 for Singapore data)
GCP_REGION=asia-east1

# ==========================================
# Google Cloud Storage (GCS)
# ==========================================

# GCS bucket for raw data (created by Terraform)
# Default: sg-public-transport-data-raw
GCS_BUCKET_RAW=sg-public-transport-data-raw

# GCS bucket for processed data (created by Terraform)
# Default: sg-public-transport-data-processed
GCS_BUCKET_PROCESSED=sg-public-transport-data-processed

# ==========================================
# BigQuery
# ==========================================

# BigQuery dataset name (created by Terraform)
# Default: sg_public_transport_analytics
BQ_DATASET=sg_public_transport_analytics

# BigQuery dataset location (should match GCP_REGION)
BQ_LOCATION=asia-east1

# ==========================================
# LTA DataMall API
# ==========================================

# Your LTA DataMall API key
# Get it from: https://datamall.lta.gov.sg/
# Register for a free account and copy your "Account Key"
LTA_ACCOUNT_KEY=YOUR_LTA_API_KEY_HERE

# ==========================================
# Airflow Configuration
# ==========================================
# These are needed if you're running Airflow with Docker

# Airflow admin username (default: admin)
_AIRFLOW_WWW_USER_USERNAME=admin

# Airflow admin password (default: admin, change in production!)
_AIRFLOW_WWW_USER_PASSWORD=admin

# Airflow UID for volume permissions (default: 50000)
AIRFLOW_UID=50000

# ==========================================
# Notes
# ==========================================
# 
# 1. NEVER commit the actual .env file to git (it's in .gitignore)
# 2. Always use this .env.example as a template
# 3. Update terraform outputs in this file after running `terraform apply`
# 4. All services (Python scripts, Airflow, Streamlit) use this single .env file
# 5. For dbt, configure ~/.dbt/profiles.yml with absolute path to credentials
#