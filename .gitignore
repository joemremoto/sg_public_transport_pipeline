# .gitignore - Files and folders that Git should ignore
# This keeps sensitive data, generated files, and local artifacts out of version control

# ============================================================================
# Python-specific ignores
# ============================================================================

# Byte-compiled / optimized / DLL files
# These are generated when Python runs your code for faster loading next time
__pycache__/              # Folder containing compiled Python files
*.py[cod]                 # .pyc, .pyo, .pyd files
*$py.class                # More compiled files

# C extensions (compiled code)
*.so                      # Shared object files (Linux/Mac)
*.dll                     # Dynamic link libraries (Windows)
*.dylib                   # Dynamic libraries (Mac)

# Distribution / packaging
# These are created when building your project for distribution
.Python                   # Python installation marker
build/                    # Build artifacts
develop-eggs/
dist/                     # Distribution packages (when you run: uv build)
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/              # Package metadata
.installed.cfg
*.egg
MANIFEST

# PyInstaller
# If you bundle your Python app into an executable
*.manifest
*.spec

# ============================================================================
# Virtual Environments
# ============================================================================

# uv creates a .venv folder with all your installed packages
# This should NEVER be committed - each developer creates their own
.venv/                   # uv's virtual environment
venv/                    # Alternative venv name
ENV/
env/
.python-version          # Python version file (if using pyenv)

# ============================================================================
# Testing & Coverage
# ============================================================================

# pytest cache
.pytest_cache/           # pytest stores test results here
.tox/                    # Testing tool cache
.nox/                    # Another testing tool
.coverage                # Code coverage data
.coverage.*
htmlcov/                 # HTML coverage reports
*.cover
*.py,cover
.hypothesis/             # Property-based testing cache
.cache/                  # General cache folder

# ============================================================================
# Jupyter Notebook (if used for exploration)
# ============================================================================

.ipynb_checkpoints       # Jupyter auto-saves
*.ipynb                  # Uncomment if you don't want to commit notebooks

# ============================================================================
# Environment Variables & Credentials
# ============================================================================

# CRITICAL: These files contain secrets and must NEVER be committed!
.env
.env.*
*.env
!.env.example            # Exception: allow .env.example template files

# Credentials & keys
credentials/
*.json
!pyproject.toml          # Exception: allow pyproject.toml
*.pem                    # Private key files
*.key                    # Key files
*.crt                    # Certificate files
*.p12                    # Certificate bundles
*.pfx                    # Certificate files
secrets.*                # Any file starting with "secrets"

# ============================================================================
# Data Files (Local Storage)
# ============================================================================

# Your data/ folder should NOT be committed - it can get huge!
data/                    # All local data
*.csv                    # CSV files (from LTA API)
*.parquet                # Parquet files (compressed data)
*.zip                    # ZIP files (LTA API downloads)
*.gz                     # Gzip compressed files
*.tar                    # Tar archives

# But allow sample/example data (if you create it)
!data/samples/
!data/examples/

# ============================================================================
# IDE & Editor Files
# ============================================================================

# VSCode
.vscode/                 # VSCode settings (personal preferences)
!.vscode/settings.json   # Uncomment if you want shared team settings
!.vscode/launch.json
!.vscode/extensions.json

# Cursor
.cursor/                 # Cursor IDE files
!.cursor/rules/          # Keep cursor rules for the project

# PyCharm
.idea/                   # PyCharm project files
*.iml

# Other editors
.DS_Store                # macOS file manager metadata
Thumbs.db                # Windows thumbnail cache
*.swp                    # Vim swap files
*.swo                    # Vim swap files
*~                       # Backup files

# ============================================================================
# Docker
# ============================================================================

# Docker volumes and build cache
docker-compose.override.yml  # Local docker-compose overrides
.docker/                     # Docker build cache

# Docker environment
.env.docker                  # Docker-specific environment variables

# ============================================================================
# Terraform (when we add it later)
# ============================================================================

# Terraform state and variables
*.tfstate                # Terraform state (contains infrastructure info)
*.tfstate.*
*.tfvars                 # Terraform variables (may contain sensitive values)
.terraform/              # Terraform plugins and modules
.terraform.lock.hcl      # Uncomment if you want to ignore lock file

# ============================================================================
# Logs & Temporary Files
# ============================================================================

# Application logs
*.log                    # Log files
logs/                    # Logs directory
*.out                    # Output files
*.err                    # Error files

# Airflow
airflow/logs/            # Airflow execution logs (generated at runtime)
airflow/*.db             # Airflow SQLite database (local only)
airflow/*.pid            # Process ID files
airflow/airflow.cfg      # Local Airflow config (use template instead)
airflow/webserver_config.py  # Auto-generated webserver config

# Airflow runtime directories
airflow/__pycache__/     # Python cache in Airflow directory

# Streamlit
streamlit_app/.streamlit/secrets.toml
.streamlit/secrets.toml

# Temporary files
tmp/                     # Temporary directory
temp/                    # Alternative temp directory
*.tmp                    # Temporary files
.cache/                  # Cache directory

# ============================================================================
# Terraform State Files
# ============================================================================

# Terraform state (contains sensitive data and resource IDs)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform variable files (may contain secrets)
terraform.tfvars
*.auto.tfvars

# Terraform directories
.terraform/
.terraform.lock.hcl

# Crash log files
crash.log
crash.*.log

# Override files (local customizations)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan output
*.tfplan

# ============================================================================
# Operating System Files
# ============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini

# Linux
*~
.directory
.Trash-*

# ============================================================================
# Documentation Build Files
# ============================================================================

# Sphinx documentation (if we add it)
docs/_build/
docs/.doctrees/

# ============================================================================
# Project-specific ignores
# ============================================================================

*.pyc
*.csv


# ============================================================================
# Important: What SHOULD be committed
# ============================================================================

# DO commit:
# - Source code (src/)
# - Tests (tests/)
# - Documentation (docs/, README.md, glossary.md)
# - Configuration templates (.env.example)
# - Dependency files (pyproject.toml, uv.lock)
# - Dockerfile, docker-compose.yml
# - Terraform configs (*.tf) but NOT *.tfvars
# - .gitignore (this file!)

# DO NOT commit:
# - .env (has secrets!)
# - data/ (too large, can be regenerated)
# - Virtual environments (.venv/)
# - Compiled files (__pycache__/)
# - IDE settings (personal preference)

# ============================================================================
# dbt (Data Build Tool) 
# ============================================================================

# dbt artifacts (generated during runs)
sg_transport_dbt/target/          # Compiled SQL and run artifacts
sg_transport_dbt/dbt_packages/    # Installed dbt packages
sg_transport_dbt/logs/            # dbt execution logs

# dbt user-specific settings
sg_transport_dbt/.user.yml        # User-specific dbt settings

# profiles.yml typically lives in ~/.dbt/ (not in project)
# But if someone puts it in project, ignore it (contains credentials!)
sg_transport_dbt/profiles.yml

# ============================================================================
# Docker & Airflow Runtime (Phase 6)
# ============================================================================

# Docker runtime
docker-compose.override.yml
.docker/

# Airflow runtime and generated files
airflow/logs/
airflow/__pycache__/
airflow/*.db
airflow/*.pid
airflow/airflow.cfg
airflow/webserver_config.py

# PostgreSQL data (from docker-compose volumes)
postgres-data/

# ============================================================================
# Important: What SHOULD be committed from Phase 6
# ============================================================================

# DO commit:
# - docker-compose.yml (service orchestration)
# - Dockerfile (custom Airflow image)
# - .dockerignore (build optimization)
# - airflow/dags/ (DAG definitions)
# - airflow/config/ (configuration files)
# - airflow/requirements.txt (Python dependencies)
# - airflow/plugins/ (custom operators)
# - airflow/README.md (documentation)

# DO NOT commit:
# - .env (contains credentials/secrets)
# - airflow/logs/ (runtime logs)
# - airflow/*.db (local database files)
# - docker-compose.override.yml (personal overrides)

