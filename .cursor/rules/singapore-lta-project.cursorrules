```python
import zipfile
import io

# Download and extract in memory (links expire in 5 min!)
file_response = requests.get(download_link, timeout=300)
zip_file = zipfile.ZipFile(io.BytesIO(file_response.content))
zip_file.extractall(output_dir)
```

