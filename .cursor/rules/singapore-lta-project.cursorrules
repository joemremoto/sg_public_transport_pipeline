### Package Management with uv:
```bash
# Install uv (Python package manager - faster alternative to pip)
# uv manages Python packages and virtual environments
curl -LsSf https://astral.sh/uv/install.sh | sh

# Create new Python project with uv
# This sets up a pyproject.toml file to track dependencies
uv init

# Add a package (example: requests library for HTTP calls)
# uv automatically updates pyproject.toml
uv add requests

# Install all project dependencies
# Reads pyproject.toml and installs everything listed
uv sync

# Run Python script with uv
# Ensures script runs in the correct virtual environment
uv run python script.py
```

### Docker Integration:
**All components must be containerized for reproducibility**

```dockerfile
# Example: Dockerfile for Python data ingestion scripts
# FROM = base image to build upon
FROM python:3.11-slim

# Set working directory inside container
# WORKDIR = where files will be copied and commands will run
WORKDIR /app

# Install uv package manager
# RUN = execute command during image build
RUN pip install uv

# Copy dependency files first (for Docker layer caching)
# COPY source destination
COPY pyproject.toml uv.lock ./

# Install dependencies using uv
RUN uv sync --frozen

# Copy application code
COPY . .

# Set environment variables
# ENV = set variable that persists in running container
ENV PYTHONUNBUFFERED=1

# Command to run when container starts
# CMD = default command (can be overridden)
CMD ["uv", "run", "python", "main.py"]
```

```yaml
# docker-compose.yml - Orchestrates multiple containers
# This file defines all services and how they work together
version: '3.8'

services:
  # Airflow webserver - The UI for managing workflows
  airflow-webserver:
    build: ./airflow
    ports:
      - "8080:8080"  # Map port 8080 in container to 8080 on host
    environment:
      - AIRFLOW__CORE__EXECUTOR=LocalExecutor
      - LTA_ACCOUNT_KEY=${LTA_ACCOUNT_KEY}  # Pass env var from .env file
    volumes:
      - ./dags:/opt/airflow/dags  # Mount DAGs folder so changes reflect immediately
    depends_on:
      - postgres  # Wait for postgres to start first

  # PostgreSQL - Database for Airflow metadata
  postgres:
    image: postgres:13
    environment:
      - POSTGRES_USER=airflow
      - POSTGRES_PASSWORD=airflow
      - POSTGRES_DB=airflow
    volumes:
      - postgres-db-volume:/var/lib/postgresql/data

volumes:
  postgres-db-volume:  # Persistent storage for database
```

### Terraform Best Practices:
**Use Terraform to provision all Google Cloud infrastructure**

```hcl
# main.tf - Define Google Cloud resources
# Terraform = Infrastructure as Code (IaC) tool

# Provider configuration - Connect to Google Cloud
# Provider = plugin that talks to cloud platform APIs
provider "google" {
  project = var.project_id  # Google Cloud project ID
  region  = var.region      # Default region (e.g., us-central1)
}

# GCS bucket for raw data storage
# resource = infrastructure component to create
resource "google_storage_bucket" "raw_data" {
  name          = "${var.project_id}-lta-raw-data"  # Bucket names must be globally unique
  location      = var.region
  force_destroy = false  # Prevent accidental deletion

  # Lifecycle rule - Automatically move old data to cheaper storage
  lifecycle_rule {
    action {
      type          = "SetStorageClass"
      storage_class = "NEARLINE"  # Cheaper storage for data accessed <1/month
    }
    condition {
      age = 90  # Apply after 90 days
    }
  }
}

# BigQuery dataset for transformed data
resource "google_bigquery_dataset" "lta_analytics" {
  dataset_id  = "lta_analytics"
  description = "Singapore LTA public transport analytics"
  location    = var.region
}

# Variables - Reusable values
variable "project_id" {
  description = "Google Cloud Project ID"
  type        = string
}

variable "region" {
  description = "Google Cloud region"
  type        = string
  default     = "asia-southeast1"  # Singapore region
}
```

**Terraform Workflow:**
```bash
# Initialize Terraform (downloads provider plugins)
terraform init

# Preview changes before applying
# Always run this first to see what will be created/modified
terraform plan

# Apply infrastructure changes
# Creates/updates cloud resources based on .tf files
terraform apply

# Destroy all infrastructure (cleanup)
# BE CAREFUL - This deletes everything!
terraform destroy
```

